{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@regardio/brand",
  "version": "0.12.0",
  "private": false,
  "description": "Regardio Brand Assets",
  "homepage": "https://github.com/regardio/brand#readme",
  "bugs": {
    "url": "https://github.com/regardio/brand/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/regardio/brand.git"
  },
  "license": "CC BY-SA 4.0",
  "author": "Bernd Matzner <bernd.matzner@regard.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./button": {
      "types": "./dist/components/button.d.mts",
      "import": "./dist/components/button.mjs",
      "default": "./dist/components/button.mjs"
    },
    "./styles/*": "./dist/styles/*",
    "./sprites/*": "./dist/generated/sprites/*",
    "./icons/*": "./dist/generated/icons/*",
    "./icons/regardio-ensemble-icon-color": {
      "import": "./dist/generated/icons/regardio-ensemble-icon-color.mjs",
      "types": "./dist/generated/icons/regardio-ensemble-icon-color.d.mts"
    },
    "./icons/regardio-ensemble-icon-color-full": {
      "import": "./dist/generated/icons/regardio-ensemble-icon-color-full.mjs",
      "types": "./dist/generated/icons/regardio-ensemble-icon-color-full.d.mts"
    },
    "./icons/regardio-ensemble-icon-mono": {
      "import": "./dist/generated/icons/regardio-ensemble-icon-mono.mjs",
      "types": "./dist/generated/icons/regardio-ensemble-icon-mono.d.mts"
    },
    "./icons/regardio-icon-color": {
      "import": "./dist/generated/icons/regardio-icon-color.mjs",
      "types": "./dist/generated/icons/regardio-icon-color.d.mts"
    },
    "./icons/regardio-icon-color-full": {
      "import": "./dist/generated/icons/regardio-icon-color-full.mjs",
      "types": "./dist/generated/icons/regardio-icon-color-full.d.mts"
    },
    "./icons/regardio-icon-mono": {
      "import": "./dist/generated/icons/regardio-icon-mono.mjs",
      "types": "./dist/generated/icons/regardio-icon-mono.d.mts"
    },
    "./icons/regardio-logo-color": {
      "import": "./dist/generated/icons/regardio-logo-color.mjs",
      "types": "./dist/generated/icons/regardio-logo-color.d.mts"
    },
    "./icons/regardio-logo-color-light": {
      "import": "./dist/generated/icons/regardio-logo-color-light.mjs",
      "types": "./dist/generated/icons/regardio-logo-color-light.d.mts"
    },
    "./icons/regardio-logo-mono": {
      "import": "./dist/generated/icons/regardio-logo-mono.mjs",
      "types": "./dist/generated/icons/regardio-logo-mono.d.mts"
    },
    "./icons/regardio-logo-mono-light": {
      "import": "./dist/generated/icons/regardio-logo-mono-light.mjs",
      "types": "./dist/generated/icons/regardio-logo-mono-light.d.mts"
    },
    "./icons/regardio-system-icon": {
      "import": "./dist/generated/icons/regardio-system-icon.mjs",
      "types": "./dist/generated/icons/regardio-system-icon.d.mts"
    },
    "./icons/system-layer-bridges-icon": {
      "import": "./dist/generated/icons/system-layer-bridges-icon.mjs",
      "types": "./dist/generated/icons/system-layer-bridges-icon.d.mts"
    },
    "./icons/system-layer-circles-icon": {
      "import": "./dist/generated/icons/system-layer-circles-icon.mjs",
      "types": "./dist/generated/icons/system-layer-circles-icon.d.mts"
    },
    "./icons/system-layer-facets-icon": {
      "import": "./dist/generated/icons/system-layer-facets-icon.mjs",
      "types": "./dist/generated/icons/system-layer-facets-icon.d.mts"
    },
    "./icons/system-layer-sources-icon": {
      "import": "./dist/generated/icons/system-layer-sources-icon.mjs",
      "types": "./dist/generated/icons/system-layer-sources-icon.d.mts"
    },
    "./icons/system-layer-plans-icon": {
      "import": "./dist/generated/icons/system-layer-plans-icon.mjs",
      "types": "./dist/generated/icons/system-layer-plans-icon.d.mts"
    },
    "./icons/system-layer-pursuits-icon": {
      "import": "./dist/generated/icons/system-layer-pursuits-icon.mjs",
      "types": "./dist/generated/icons/system-layer-pursuits-icon.d.mts"
    },
    "./sprites/compass-sprite": {
      "import": "./dist/generated/sprites/compass-sprite.mjs",
      "types": "./dist/generated/sprites/compass-sprite.d.mts"
    },
    "./sprites/compass-sprite-provider": {
      "import": "./dist/generated/sprites/compass-sprite-provider.mjs",
      "types": "./dist/generated/sprites/compass-sprite-provider.d.mts"
    }
  },
  "files": ["dist", "src/styles", "src/components"],
  "scripts": {
    "build": "tsdown",
    "clean": "exec-clean .turbo dist src/generated",
    "dev": "tsdown --watch",
    "fix": "exec-s fix:pkg fix:md fix:biome",
    "fix:biome": "lint-biome check --write --unsafe .",
    "fix:md": "lint-md --fix",
    "fix:pkg": "lint-package --fix",
    "generate": "exec-s generate:* post-generate:* fix:*",
    "generate:compass-base-sprite": "tsx scripts/convert-svgs-to-sprite.ts ./src/svg/compass-base ./src/generated/sprites/compass-base.svg",
    "generate:compass-base-sprites-components": "tsx scripts/build-compass-base-sprites.ts",
    "generate:icons": "svgr --icon --out-dir ./src/generated/icons -- ./src/svg/icons",
    "lint": "exec-s lint:md lint:biome",
    "lint:biome": "lint-biome check .",
    "lint:md": "lint-md",
    "lint:pkg": "lint-package",
    "post-generate:add-return-types": "tsx scripts/post-generate-add-return-types.ts",
    "prepare": "exec-husky",
    "report": "vitest run --coverage",
    "ship:hotfix": "ship-hotfix",
    "ship:production": "ship-production",
    "ship:staging": "ship-staging",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "test:unit": "vitest run",
    "test": "exec-s test:*",
    "tsdown": "tsdown",
    "typecheck": "exec-tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/georama": "5.2.8",
    "@regardio/react": "workspace:*",
    "@regardio/tailwind": "workspace:*"
  },
  "devDependencies": {
    "@regardio/dev": "workspace:*",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@svgr/cli": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@svgr/plugin-svgo": "8.1.0",
    "@tailwindcss/vite": "4.2.2",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "linkedom": "0.18.12",
    "node-html-parser": "7.1.0",
    "playwright": "1.59.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "storybook": "10.3.5",
    "svgo": "4.0.1",
    "tailwindcss": "4.2.2",
    "tsdown": "0.21.8",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
